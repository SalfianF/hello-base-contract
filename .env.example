# ANBLE Token Deployment Configuration
# Copy to .env and fill in your values.
#   cp .env.example .env

# --- Network ---
# Mainnet:  https://mainnet.base.org
# Sepolia:  https://sepolia.base.org
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# --- Wallet ---
# Deployer private key (hex with 0x prefix)
PRIVATE_KEY=

# --- Contract ---
# Owner address (defaults to deployer if unset)
OWNER_ADDRESS=
# Initial supply in wei (default: 500_000_000 * 10**18)
INITIAL_SUPPLY=

# --- Verification ---
BASESCAN_API_KEY=
